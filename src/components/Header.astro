---
import { SITE_TITLE, CATEGORIES } from '../consts.ts';
// Show the first 5 categories in the top nav to keep it tidy.
const topNav = CATEGORIES.slice(0, 5);
---
<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/">🐾 {SITE_TITLE}</a>
    <nav class="nav" aria-label="Primary">
      {topNav.map((c) => (
        <a href={`/category/${c.slug}`}>{c.label}</a>
      ))}
      <a href="/categories">All Pets</a>
      <a href="/tools">Tools</a>
      <a href="/places">Pet Places</a>
      <a href="/search">Search</a>
      <a href="/senior-pets">Senior Pets</a>
      <a href="/about">About</a>
      <a href="/login" class="nav-account">Log in</a>
    </nav>
  </div>
</header>
