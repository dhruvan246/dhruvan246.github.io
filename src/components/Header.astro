---
import { SITE_TITLE } from '../consts.ts';

const navLinks = [
  { href: '/category/dogs', label: 'Dogs' },
  { href: '/category/cats', label: 'Cats' },
  { href: '/category/birds', label: 'Birds' },
  { href: '/category/fish', label: 'Fish' },
  { href: '/category/reptiles', label: 'Reptiles' },
  { href: '/categories', label: 'All Pets' },
  { href: '/tools', label: 'Tools' },
  { href: '/places', label: 'Pet Places' },
  { href: '/senior-pets', label: 'Senior Pets' },
  { href: '/search', label: 'Search' },
  { href: '/about', label: 'About' },
];
---
<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="34" height="34">
          <rect width="64" height="64" rx="16" fill="#2f8f63" />
          <g fill="#ffffff">
            <circle cx="22" cy="24" r="6" /><circle cx="42" cy="24" r="6" />
            <circle cx="14" cy="36" r="5" /><circle cx="50" cy="36" r="5" />
            <path d="M32 32c-7 0-12 6-12 12 0 5 4 7 12 7s12-2 12-7c0-6-5-12-12-12z" />
          </g>
        </svg>
      </span>
      <span class="brand-name">{SITE_TITLE}</span>
    </a>

    <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
      <span class="nav-toggle-bars"></span>
    </button>

    <nav class="nav" id="site-nav" aria-label="Primary">
      {navLinks.map((n) => <a href={n.href}>{n.label}</a>)}
      <a href="/login" class="nav-account" id="nav-account-link">Log in</a>
    </nav>
  </div>
</header>

<script is:inline>
  // Mobile menu toggle.
  (function () {
    var t = document.getElementById('nav-toggle');
    var n = document.getElementById('site-nav');
    if (!t || !n) return;
    function setOpen(open) {
      n.classList.toggle('open', open);
      t.classList.toggle('open', open);
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
      t.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    }
    t.addEventListener('click', function () { setOpen(!n.classList.contains('open')); });
    n.addEventListener('click', function (e) { if (e.target.closest('a')) setOpen(false); });
  })();

  // Reflect Supabase login state: show the user's name (or email) in the nav.
  (function () {
    try {
      var key = Object.keys(localStorage).find(function (k) {
        return k.indexOf('sb-') === 0 && k.indexOf('-auth-token') > -1;
      });
      if (!key) return;
      var sess = JSON.parse(localStorage.getItem(key) || 'null');
      var user = sess && (sess.user || (sess.currentSession && sess.currentSession.user));
      if (!user) return;
      var meta = user.user_metadata || {};
      var name = meta.full_name || meta.name || meta.user_name ||
                 (user.email ? user.email.split('@')[0] : null);
      if (!name) return;
      var link = document.getElementById('nav-account-link');
      if (link) {
        link.textContent = '👤 ' + name;
        link.setAttribute('title', 'View account / log out');
      }
    } catch (e) { /* not logged in — leave "Log in" */ }
  })();
</script>
