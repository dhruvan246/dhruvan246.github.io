---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
---
<BaseLayout
  title="Pet-Friendly Places Near You — Vets, Pet Shops & Dog Parks"
  description="Find veterinary clinics, pet shops and dog parks near you on a live map. Free, powered by OpenStreetMap — just share your location or search a place."
>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <section class="hero">
    <div class="container">
      <h1>📍 Pet Places Near You</h1>
      <p>Find vets, pet shops and dog parks nearby — shown on a live map <strong>and listed below with addresses &amp; directions</strong>. Free and no sign-up.</p>
    </div>
  </section>

  <div class="container">
    <AdSlot />

    <div class="places-controls">
      <button id="locate" class="btn-primary">📍 Use my location</button>
      <form id="place-search" class="place-search">
        <input id="place-q" type="text" placeholder="…or type a city or area" autocomplete="off" />
        <button type="submit" class="btn-ghost">Search</button>
      </form>
    </div>

    <div class="places-filters">
      <label class="opt"><input type="checkbox" id="f-vet" checked /><span class="opt-card"><span class="dot" style="background:#e74c3c"></span> Vets</span></label>
      <label class="opt"><input type="checkbox" id="f-pet" checked /><span class="opt-card"><span class="dot" style="background:#2f8f63"></span> Pet shops</span></label>
      <label class="opt"><input type="checkbox" id="f-park" checked /><span class="opt-card"><span class="dot" style="background:#f0a202"></span> Dog parks</span></label>
      <label class="opt"><input type="checkbox" id="f-shelter" checked /><span class="opt-card"><span class="dot" style="background:#7e57c2"></span> Shelters &amp; boarding</span></label>
    </div>

    <p id="places-status" class="sub">Share your location or search a place to begin.</p>
    <p id="gmaps-more-wrap" hidden style="margin:-4px 0 12px;">
      <a id="gmaps-more" class="btn-ghost btn-sm" target="_blank" rel="noopener">🔎 See even more on Google Maps →</a>
      <span class="sub" style="margin-left:8px;">Our map uses free community data; Google has more listings.</span>
    </p>
    <div id="map" class="places-map"></div>
    <ul id="places-list" class="place-list"></ul>

    <p class="disclaimer">Places come from <a href="https://www.openstreetmap.org" target="_blank" rel="noopener">OpenStreetMap</a> — a free, community-mapped database. Coverage of small businesses can be patchy (especially outside major cities), so some local vets and pet shops may not appear here yet. Always verify details before visiting.</p>
    <AdSlot />
  </div>
</BaseLayout>

<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script is:inline>
  const TYPES = {
    vet:     { label: 'Vet',      color: '#e74c3c' },
    pet:     { label: 'Pet shop', color: '#2f8f63' },
    park:    { label: 'Dog park', color: '#f0a202' },
    shelter: { label: 'Shelter',  color: '#7e57c2' },
  };
  // Which OSM tags we ask Overpass for (broad, to catch as many pet places as
  // OpenStreetMap has). nwr = nodes + ways + relations.
  const OSM_TAGS = [
    'amenity=veterinary', 'healthcare=veterinary',
    'shop=pet', 'shop=pet_grooming', 'shop=pets', 'craft=dog_trainer',
    'leisure=dog_park',
    'amenity=animal_shelter', 'amenity=animal_boarding', 'amenity=animal_breeding',
  ];
  function classify(t) {
    if (!t) return null;
    if (t.amenity === 'veterinary' || t.healthcare === 'veterinary') return 'vet';
    if (t.shop === 'pet' || t.shop === 'pet_grooming' || t.shop === 'pets' || t.craft === 'dog_trainer') return 'pet';
    if (t.leisure === 'dog_park') return 'park';
    if (t.amenity === 'animal_shelter' || t.amenity === 'animal_boarding' || t.amenity === 'animal_breeding') return 'shelter';
    return null;
  }
  const RADIUS_M = 12000; // 12 km

  const statusEl = document.getElementById('places-status');
  const listEl = document.getElementById('places-list');
  let map, layer, userMarker, results = [], center = null;
  const markerByKey = {};
  const active = { vet: true, pet: true, park: true, shelter: true };

  const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
  function setStatus(t) { statusEl.textContent = t; }
  function fmtAddr(t) {
    if (!t) return '';
    const line = [t['addr:housenumber'], t['addr:street']].filter(Boolean).join(' ');
    return [line, t['addr:city'], t['addr:postcode']].filter(Boolean).join(', ');
  }
  function distKm(aLat, aLon, bLat, bLon) {
    const R = 6371, toR = (x) => x * Math.PI / 180;
    const dLat = toR(bLat - aLat), dLon = toR(bLon - aLon);
    const s = Math.sin(dLat / 2) ** 2 + Math.cos(toR(aLat)) * Math.cos(toR(bLat)) * Math.sin(dLon / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(s), Math.sqrt(1 - s));
  }
  function popupHtml(r) {
    return `<b>${esc(r.name)}</b><br>${TYPES[r.type].label}` +
      (r.addr ? `<br><small>${esc(r.addr)}</small>` : '') +
      `<br><a href="https://www.google.com/maps/dir/?api=1&destination=${r.lat},${r.lon}" target="_blank" rel="noopener">Directions ↗</a>`;
  }

  function initMap() {
    if (map) return;
    map = L.map('map').setView([20, 0], 2);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors', maxZoom: 19,
    }).addTo(map);
    layer = L.layerGroup().addTo(map);
  }

  function render() {
    if (!layer) return;
    layer.clearLayers();
    Object.keys(markerByKey).forEach((k) => delete markerByKey[k]);

    let shown = results.filter((r) => active[r.type]);
    if (center) shown.forEach((r) => { r.km = distKm(center.lat, center.lon, r.lat, r.lon); });
    shown.sort((a, b) => (a.km ?? 1e9) - (b.km ?? 1e9));

    shown.forEach((r, i) => {
      const c = TYPES[r.type].color;
      markerByKey[i] = L.circleMarker([r.lat, r.lon], { radius: 8, color: c, fillColor: c, fillOpacity: 0.85, weight: 2 })
        .addTo(layer).bindPopup(popupHtml(r));
    });

    setStatus(shown.length
      ? `${shown.length} pet places found nearby — see the full list below the map.`
      : 'No matching places found nearby — try widening your filters or a bigger area.');

    listEl.innerHTML = shown.map((r, i) => {
      const t = TYPES[r.type];
      return `<li class="place-item" data-i="${i}" data-lat="${r.lat}" data-lon="${r.lon}">
        <span class="place-rank">${i + 1}</span>
        <div class="place-body">
          <div class="place-name"><span class="dot" style="background:${t.color}"></span> ${esc(r.name)}<span class="place-type">${t.label}</span></div>
          ${r.addr ? `<div class="place-addr">📍 ${esc(r.addr)}</div>` : `<div class="place-addr place-addr-none">Address not listed on OpenStreetMap</div>`}
          <div class="place-meta">${r.km != null ? `<strong>${r.km.toFixed(1)} km</strong> away · ` : ''}<a class="place-dir" href="https://www.google.com/maps/dir/?api=1&destination=${r.lat},${r.lon}" target="_blank" rel="noopener">Directions ↗</a></div>
        </div>
      </li>`;
    }).join('');

    listEl.querySelectorAll('.place-item').forEach((li) => {
      li.addEventListener('click', (e) => {
        if (e.target.closest('a')) return;
        const m = markerByKey[li.dataset.i];
        if (m && map) {
          map.setView([+li.dataset.lat, +li.dataset.lon], 16);
          m.openPopup();
          document.getElementById('map').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  async function searchAt(lat, lon, label) {
    initMap();
    center = { lat, lon };
    map.setView([lat, lon], 13);
    const g = document.getElementById('gmaps-more');
    if (g) { g.href = `https://www.google.com/maps/search/pet+care+vet+pet+shop/@${lat},${lon},14z`; document.getElementById('gmaps-more-wrap').hidden = false; }
    if (userMarker) map.removeLayer(userMarker);
    userMarker = L.circleMarker([lat, lon], { radius: 7, color: '#226b4a', fillColor: '#226b4a', fillOpacity: 1 })
      .addTo(map).bindPopup(label || 'You are here');
    setStatus('Searching for nearby pet places…');
    // Build a broad Overpass query across all our tags, matching nodes, ways
    // AND relations (some places are mapped as buildings/areas, not points).
    const parts = OSM_TAGS.map((tag) => {
      const [k, v] = tag.split('=');
      return `nwr["${k}"="${v}"](around:${RADIUS_M},${lat},${lon});`;
    }).join('');
    const query = `[out:json][timeout:30];(${parts});out center 300;`;
    try {
      const res = await fetch('https://overpass-api.de/api/interpreter', {
        method: 'POST', body: 'data=' + encodeURIComponent(query),
      });
      const data = await res.json();
      const seen = new Set();
      results = (data.elements || []).map((e) => {
        const plat = e.lat != null ? e.lat : (e.center && e.center.lat);
        const plon = e.lon != null ? e.lon : (e.center && e.center.lon);
        const type = classify(e.tags);
        if (plat == null || plon == null || !type) return null;
        return { lat: plat, lon: plon, name: (e.tags && e.tags.name) || '(unnamed place)', addr: fmtAddr(e.tags), type };
      }).filter(Boolean).filter((r) => {
        const key = r.name + '@' + r.lat.toFixed(4) + ',' + r.lon.toFixed(4);
        if (seen.has(key)) return false;
        seen.add(key); return true;
      });
      render();
    } catch (err) {
      setStatus('Could not load places — the free map service may be busy. Please try again in a moment.');
    }
  }

  document.getElementById('locate').addEventListener('click', () => {
    initMap();
    if (!navigator.geolocation) { setStatus('Your browser does not support location. Try searching a place name instead.'); return; }
    setStatus('Getting your location…');
    navigator.geolocation.getCurrentPosition(
      (pos) => searchAt(pos.coords.latitude, pos.coords.longitude, 'You are here'),
      () => setStatus('Location was blocked. Type a city or area name to search instead.')
    );
  });

  document.getElementById('place-search').addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = document.getElementById('place-q').value.trim();
    if (!q) return;
    initMap();
    setStatus('Finding that place…');
    try {
      const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(q)}`);
      const data = await res.json();
      if (!data.length) { setStatus('Could not find that place — try a different spelling.'); return; }
      searchAt(parseFloat(data[0].lat), parseFloat(data[0].lon), data[0].display_name.split(',')[0]);
    } catch (err) { setStatus('Search failed — please try again.'); }
  });

  ['vet', 'pet', 'park', 'shelter'].forEach((k) => {
    document.getElementById('f-' + k).addEventListener('change', (e) => { active[k] = e.target.checked; render(); });
  });

  initMap();
</script>
