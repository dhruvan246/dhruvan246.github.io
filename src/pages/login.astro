---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SUPABASE_URL, SUPABASE_ANON_KEY, REVIEWS_ENABLED, OAUTH_PROVIDERS } from '../lib/supabase.ts';

const PROVIDER_META: Record<string, { label: string; emoji: string }> = {
  google: { label: 'Continue with Google', emoji: '🔵' },
  github: { label: 'Continue with GitHub', emoji: '🐙' },
  facebook: { label: 'Continue with Facebook', emoji: '📘' },
  twitter: { label: 'Continue with X (Twitter)', emoji: '✖️' },
  azure: { label: 'Continue with Microsoft', emoji: '🪟' },
};
const providers = OAUTH_PROVIDERS.filter((p) => PROVIDER_META[p]).map((p) => ({ id: p, ...PROVIDER_META[p] }));
---
<BaseLayout title="Log in / Sign up" description="Log in or create a free PawPedia account to leave owner reviews and share photos of your pets.">
  <section class="hero">
    <div class="container">
      <h1>🐾 PawPedia Account</h1>
      <p>Log in or sign up to leave owner reviews and share photos.</p>
    </div>
  </section>

  <div class="container">
    {!REVIEWS_ENABLED ? (
      <p class="page sub">Accounts are launching soon — check back shortly!</p>
    ) : (
      <div class="tool" style="max-width:440px;">
        <div id="auth-status" class="result-box" hidden></div>

        {providers.length > 0 && (
          <div class="oauth-list" id="oauth-section">
            {providers.map((p) => (
              <button type="button" class="btn-oauth" data-provider={p.id}>
                {p.id === 'google' ? (
                  <svg class="oauth-logo" width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path fill="#4285F4" d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
                    <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
                    <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
                    <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
                  </svg>
                ) : (
                  <span aria-hidden="true">{p.emoji}</span>
                )} {p.label}
              </button>
            ))}
            <div class="oauth-divider"><span>or use email</span></div>
          </div>
        )}

        <form id="auth-form" class="tool">
          <div class="field">
            <label class="field-label" for="email">Email</label>
            <input id="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label class="field-label" for="password">Password</label>
            <input id="password" type="password" autocomplete="current-password" minlength="6" required />
          </div>
          <div class="matcher-actions">
            <button type="submit" id="btn-login" class="btn-primary">Log in</button>
            <button type="button" id="btn-signup" class="btn-ghost">Create account</button>
          </div>
          <p id="auth-msg" class="rv-msg"></p>
        </form>
        <p id="auth-loggedin" hidden>
          You're logged in as <strong id="auth-email"></strong>.
          <button id="btn-logout" class="btn-ghost btn-sm" style="margin-left:8px;">Log out</button>
        </p>
      </div>
    )}
  </div>

  {REVIEWS_ENABLED && (
    <>
      <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
      <script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
        function startAuth() {
        const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
          auth: { lock: async (_name, _timeout, fn) => await fn() }
        });
        const form = document.getElementById('auth-form');
        const msg = document.getElementById('auth-msg');
        const loggedIn = document.getElementById('auth-loggedin');
        const emailLbl = document.getElementById('auth-email');

        const oauthSection = document.getElementById('oauth-section');
        async function refresh() {
          const { data: { user } } = await sb.auth.getUser();
          if (user) {
            form.hidden = true; loggedIn.hidden = false; emailLbl.textContent = user.email;
            if (oauthSection) oauthSection.hidden = true;
          } else {
            form.hidden = false; loggedIn.hidden = true;
            if (oauthSection) oauthSection.hidden = false;
          }
        }
        const creds = () => ({ email: document.getElementById('email').value.trim(), password: document.getElementById('password').value });

        // Shared validation so an empty field never reaches Supabase (an empty
        // email makes Supabase attempt an anonymous sign-in → confusing error).
        function validate(c) {
          if (!c.email) { msg.textContent = '⚠️ Please enter your email address.'; return false; }
          if (!c.password || c.password.length < 6) { msg.textContent = '⚠️ Password must be at least 6 characters.'; return false; }
          return true;
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const c = creds();
          if (!validate(c)) return;
          msg.textContent = 'Logging in…';
          const { error } = await sb.auth.signInWithPassword(c);
          msg.textContent = error ? ('Error: ' + error.message) : '✅ Logged in!';
          if (!error) refresh();
        });
        document.getElementById('btn-signup').addEventListener('click', async () => {
          const c = creds();
          if (!validate(c)) return;
          msg.textContent = 'Creating account…';
          const { error } = await sb.auth.signUp(c);
          msg.textContent = error ? ('Error: ' + error.message) : '✅ Account created — you are now logged in. Visit any breed page to leave a review!';
          if (!error) refresh();
        });
        document.getElementById('btn-logout').addEventListener('click', async () => { await sb.auth.signOut(); refresh(); });

        // Social login (Google / GitHub / etc.) — buttons only exist for
        // providers enabled in OAUTH_PROVIDERS.
        document.querySelectorAll('.btn-oauth').forEach((b) => {
          b.addEventListener('click', async () => {
            msg.textContent = 'Redirecting…';
            const { error } = await sb.auth.signInWithOAuth({
              provider: b.dataset.provider,
              options: { redirectTo: window.location.origin + '/login/' },
            });
            if (error) msg.textContent = 'Error: ' + error.message;
          });
        });

        refresh();
        }
        if (window.supabase && window.supabase.createClient) { startAuth(); }
        else {
          let _n = 0;
          const _iv = setInterval(function () {
            if (window.supabase && window.supabase.createClient) { clearInterval(_iv); startAuth(); }
            else if (++_n > 120) { clearInterval(_iv); }
          }, 50);
        }
      </script>
    </>
  )}
</BaseLayout>
