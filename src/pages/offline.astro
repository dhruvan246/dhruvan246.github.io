---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="You're offline" description="You appear to be offline.">
  <section class="hero">
    <div class="container">
      <h1>🐾 You're offline</h1>
      <p>It looks like you've lost your connection. Pages you've already visited are still available — reconnect to load new ones.</p>
      <p style="margin-top:18px;"><a class="btn-primary" href="/">Try the home page</a></p>
    </div>
  </section>
</BaseLayout>
