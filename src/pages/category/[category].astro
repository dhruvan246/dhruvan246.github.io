---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import BreedDirectory from '../../components/BreedDirectory.astro';
import { CATEGORIES } from '../../consts.ts';
import { BREED_GROUPS } from '../../data/breedGroups.ts';

// One page per category defined in consts.ts.
export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return CATEGORIES.map((cat) => {
    const posts = articles
      .filter((a) => a.data.category === cat.slug)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return { params: { category: cat.slug }, props: { cat, posts } };
  });
}

const { cat, posts } = Astro.props;

// If this category has a breed directory (e.g. dogs), show breeds grouped by size.
const groups = BREED_GROUPS[cat.slug];
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const existingSlugs = new Set(allArticles.map((a) => a.id));
---
<BaseLayout
  title={`${cat.label} — Care Guides & Articles`}
  description={cat.description}
>
  <section class="hero">
    <div class="container">
      <h1>{cat.emoji} {cat.label}</h1>
      <p>{cat.description}</p>
    </div>
  </section>

  <div class="container">
    <AdSlot />

    {groups ? (
      <section class="section">
        <h2>Browse {cat.label} by size</h2>
        <p class="sub">Pick a size, then choose a breed to read its full guide.</p>
        <BreedDirectory groups={groups} existingSlugs={existingSlugs} />
      </section>
    ) : (
      <section class="section">
        <h2>{posts.length} article{posts.length === 1 ? '' : 's'} in {cat.label}</h2>
        {posts.length === 0 ? (
          <p class="sub">No articles in this category yet — check back soon!</p>
        ) : (
          <div class="grid">
            {posts.map((a) => (
              <ArticleCard
                url={`/articles/${a.id}/`}
                title={a.data.title}
                description={a.data.description}
                category={a.data.category}
                pubDate={a.data.pubDate}
                heroImage={a.data.heroImage}
                heroImageAlt={a.data.heroImageAlt}
              />
            ))}
          </div>
        )}
      </section>
    )}
  </div>
</BaseLayout>
